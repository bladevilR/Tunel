# Claude Code / Anthropic direct API. When present, this takes precedence over LLM_*.
ANTHROPIC_API_KEY=replace-with-your-anthropic-api-key
ANTHROPIC_MODEL=replace-with-your-claude-model
# Optional; defaults to https://api.anthropic.com/v1
# ANTHROPIC_BASE_URL=https://api.anthropic.com/v1

# OpenAI-compatible fallback provider.
LLM_BASE_URL=https://kimi.a7m.com.cn/v1
LLM_API_KEY=replace-with-your-api-key
LLM_MODEL=kimi-k2.6
AMAP_JS_KEY=replace-with-your-amap-js-key
AMAP_SECURITY_CODE=replace-with-your-amap-security-code

# Server/deployment configuration.
INTERCONNECT_HOST=0.0.0.0
INTERCONNECT_PORT=8765
INTERCONNECT_SECRET_KEY=replace-with-a-server-secret
INTERCONNECT_ACCOUNT_MODE=local_anonymous
# Optional local validation account.
# INTERCONNECT_ACCOUNT_ID=local-user-demo
# INTERCONNECT_ACCOUNT_NAME=Local User

# Generated-image integration.
# disabled | local | openai-compatible provider name
GENERATED_IMAGE_PROVIDER=disabled
GENERATED_IMAGE_API_ENABLED=0
OPENAI_API_KEY=replace-with-openai-key-if-using-provider

# Optional PDF conversion for report exports. DOCX and snapshot JSON are mandatory.
INTERCONNECT_EXPORT_PDF=0
